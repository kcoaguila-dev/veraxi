# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_local_password

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=veraxi_docs

# LLM API
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_NAME=gemini-2.5-flash

# Embeddings (Local or Remote)
EMBEDDING_API_KEY=
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2

# Sentry
SENTRY_DSN=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Stripe
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Web Search (CRAG)
# Note: Ensure 'json' is enabled under search.formats in your SearXNG settings.yml, otherwise you will get a 403 Forbidden.
SEARXNG_URL="http://localhost:8080/search"

# Redis Infrastructure (for Background tasks and LangGraph Memory)
REDIS_URL=redis://localhost:6379/0

# Rate Limits
RATE_LIMIT_CHAT=100/day
RATE_LIMIT_INGEST=50/day
RATE_LIMIT_SSE=10/minute

# --- Retrieval Tuning ---
# Fallback limits if the LLM doesn't explicitly specify them
DEFAULT_SEARCH_LIMIT=10
DEFAULT_MAX_HOPS=2
